<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorPageBackground"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/spacing_xlarge"
        android:paddingEnd="@dimen/spacing_xlarge"
        android:paddingTop="16dp"
        android:paddingBottom="120dp">

        <TextView
            android:id="@+id/text_titulo_estadisticas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Estadísticas"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <LinearLayout
            android:id="@+id/layout_content"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/text_titulo_estadisticas"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- ── Resumen General ──────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Resumen General" android:textSize="18sp" android:textStyle="bold"
                android:textColor="@color/colorTextPrimary" android:layout_marginBottom="12dp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:weightSum="3" android:baselineAligned="false">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_height="110dp" android:layout_weight="1"
                    android:layout_marginEnd="6dp" app:cardCornerRadius="16dp" app:cardElevation="0dp"
                    app:strokeWidth="1dp" app:strokeColor="@color/colorDivider" android:backgroundTint="@color/colorCardBackground">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏋️" android:textSize="22sp"/>
                        <TextView android:id="@+id/text_total_entrenamientos" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0" android:textSize="22sp"
                            android:textStyle="bold" android:textColor="@color/colorTextPrimary" android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Total" android:textSize="11sp" android:textColor="@color/colorTextSecondary"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_height="110dp" android:layout_weight="1"
                    android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
                    app:cardCornerRadius="16dp" app:cardElevation="0dp"
                    app:strokeWidth="1dp" app:strokeColor="@color/colorDivider" android:backgroundTint="@color/colorCardBackground">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔥" android:textSize="22sp"/>
                        <TextView android:id="@+id/text_racha_actual" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0 días" android:textSize="18sp"
                            android:textStyle="bold" android:textColor="#F59E0B" android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Racha" android:textSize="11sp" android:textColor="@color/colorTextSecondary"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_height="110dp" android:layout_weight="1"
                    android:layout_marginStart="6dp" app:cardCornerRadius="16dp" app:cardElevation="0dp"
                    app:strokeWidth="1dp" app:strokeColor="@color/colorDivider" android:backgroundTint="@color/colorCardBackground">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📅" android:textSize="22sp"/>
                        <TextView android:id="@+id/text_entrenamientos_mes" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0" android:textSize="22sp"
                            android:textStyle="bold" android:textColor="#10B981" android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Este mes" android:textSize="11sp" android:textColor="@color/colorTextSecondary"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="8dp" app:cardCornerRadius="12dp" app:cardElevation="0dp"
                app:strokeWidth="1dp" app:strokeColor="@color/colorDivider" android:backgroundTint="@color/colorCardBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Tendencia:" android:textSize="14sp" android:textColor="@color/colorTextSecondary"/>
                    <TextView android:id="@+id/text_tendencia" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginStart="8dp"
                        android:text="→ Estable" android:textSize="14sp" android:textStyle="bold"
                        android:textColor="@color/colorTextSecondary"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Frecuencia ──────────────────────────────────────── -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Frecuencia de entrenamientos" android:textSize="18sp" android:textStyle="bold"
                android:textColor="@color/colorTextPrimary" android:layout_marginTop="28dp" android:layout_marginBottom="12dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="16dp" app:cardElevation="0dp"
                app:strokeWidth="1dp" app:strokeColor="@color/colorDivider" android:backgroundTint="@color/colorCardBackground">
                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/chart_frecuencia"
                    android:layout_width="match_parent" android:layout_height="200dp" android:padding="12dp"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Estadísticas por deporte ───────────────────────── -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Estadísticas por deporte" android:textSize="18sp" android:textStyle="bold"
                android:textColor="@color/colorTextPrimary" android:layout_marginTop="28dp" android:layout_marginBottom="12dp" />

            <!-- Chips de deportes -->
            <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:scrollbars="none" android:layout_marginBottom="12dp">
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_deportes"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    app:singleSelection="true" app:selectionRequired="true"/>
            </HorizontalScrollView>

            <!-- Cards de carrera (3 fijas) -->
            <LinearLayout android:id="@+id/layout_carrera"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:weightSum="3"
                android:baselineAligned="false" android:visibility="gone"
                android:layout_marginBottom="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_height="130dp" android:layout_weight="1"
                    android:layout_marginEnd="6dp" app:cardCornerRadius="16dp" app:cardElevation="0dp"
                    app:strokeWidth="2dp" app:strokeColor="@color/colorAccent" android:backgroundTint="@color/colorCardBackground">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="8dp">
                        <TextView android:id="@+id/card_emoji_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏆" android:textSize="24sp"/>
                        <TextView android:id="@+id/card_valor_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="22sp" android:textStyle="bold" android:textColor="@color/colorAccent" android:layout_marginTop="4dp"/>
                        <TextView android:id="@+id/card_titulo_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Métrica" android:textSize="10sp" android:textColor="@color/colorTextSecondary" android:gravity="center" android:maxLines="2"/>
                        <TextView android:id="@+id/card_sub_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mejor: 0" android:textSize="10sp" android:textColor="@color/colorTextSecondary"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_height="130dp" android:layout_weight="1"
                    android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
                    app:cardCornerRadius="16dp" app:cardElevation="0dp"
                    app:strokeWidth="2dp" app:strokeColor="@color/colorAccent" android:backgroundTint="@color/colorCardBackground">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="8dp">
                        <TextView android:id="@+id/card_emoji_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏆" android:textSize="24sp"/>
                        <TextView android:id="@+id/card_valor_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="22sp" android:textStyle="bold" android:textColor="@color/colorAccent" android:layout_marginTop="4dp"/>
                        <TextView android:id="@+id/card_titulo_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Métrica" android:textSize="10sp" android:textColor="@color/colorTextSecondary" android:gravity="center" android:maxLines="2"/>
                        <TextView android:id="@+id/card_sub_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mejor: 0" android:textSize="10sp" android:textColor="@color/colorTextSecondary"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_height="130dp" android:layout_weight="1"
                    android:layout_marginStart="6dp" app:cardCornerRadius="16dp" app:cardElevation="0dp"
                    app:strokeWidth="2dp" app:strokeColor="@color/colorAccent" android:backgroundTint="@color/colorCardBackground">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="8dp">
                        <TextView android:id="@+id/card_emoji_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏆" android:textSize="24sp"/>
                        <TextView android:id="@+id/card_valor_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="22sp" android:textStyle="bold" android:textColor="@color/colorAccent" android:layout_marginTop="4dp"/>
                        <TextView android:id="@+id/card_titulo_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Métrica" android:textSize="10sp" android:textColor="@color/colorTextSecondary" android:gravity="center" android:maxLines="2"/>
                        <TextView android:id="@+id/card_sub_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mejor: 0" android:textSize="10sp" android:textColor="@color/colorTextSecondary"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ✅ CHIP TOGGLE — Gráficas / Historial -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_vista"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_graficas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊 Gráficas"
                    android:textSize="13sp"
                    app:chipBackgroundColor="@color/colorCardBackground"
                    app:checkedIconVisible="false"
                    android:checkable="true"
                    android:checked="true"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_historial"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋 Historial"
                    android:textSize="13sp"
                    app:chipBackgroundColor="@color/colorCardBackground"
                    app:checkedIconVisible="false"
                    android:checkable="true"/>
            </com.google.android.material.chip.ChipGroup>

            <!-- ✅ SECCIÓN GRÁFICAS — dinámica -->
            <LinearLayout
                android:id="@+id/layout_graficas_deporte"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"/>

            <!-- ✅ SECCIÓN HISTORIAL — dinámica -->
            <LinearLayout
                android:id="@+id/layout_historial_deporte"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- Loading -->
        <LinearLayout android:id="@+id/layout_loading"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="center" android:padding="48dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/text_titulo_estadisticas"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <ProgressBar android:layout_width="48dp" android:layout_height="48dp" android:indeterminate="true"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Cargando estadísticas..." android:textSize="14sp"
                android:textColor="@color/colorTextSecondary" android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Error -->
        <LinearLayout android:id="@+id/layout_error"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="center" android:padding="48dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/text_titulo_estadisticas"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="❌" android:textSize="48sp"/>
            <TextView android:id="@+id/text_error" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Error al cargar" android:textSize="14sp"
                android:textColor="@color/colorTextSecondary" android:gravity="center" android:layout_marginTop="12dp"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>