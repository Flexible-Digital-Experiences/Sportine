<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorPageBackground"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="40dp">

        <!-- ══ HEADER ══════════════════════════════════════════════════════════ -->

        <ImageView
            android:id="@+id/btn_back_hc"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_flechaatras"
            android:contentDescription="Volver"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_titulo_hc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Health Connect"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@id/btn_back_hc"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/btn_back_hc"
            app:layout_constraintBottom_toBottomOf="@id/btn_back_hc" />

        <!-- Nombre del entrenamiento al que se vinculará -->
        <TextView
            android:id="@+id/tv_subtitulo_hc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="13sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginStart="52dp"
            tools:text="Vinculando a: Entrenamiento de Running"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_back_hc" />

        <View
            android:id="@+id/divider_hc"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="@color/colorDivider"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tv_subtitulo_hc"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ══ LOADING ═════════════════════════════════════════════════════════ -->

        <ProgressBar
            android:id="@+id/progress_bar_hc"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminate="true"
            android:layout_marginTop="80dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/divider_hc"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:visibility="gone" />

        <!-- ══ CONTENIDO (todos los estados viven aquí) ════════════════════════ -->

        <LinearLayout
            android:id="@+id/layout_contenido_hc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/divider_hc"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- ─────────────────────────────────────────────────────────────── -->
            <!-- ESTADO 1: HC no disponible en el dispositivo                   -->
            <!-- ─────────────────────────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_hc_no_disponible"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white"
                tools:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="32dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠️"
                        android:textSize="48sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Health Connect no disponible"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorTextPrimary"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Para sincronizar tus métricas necesitas instalar Health Connect desde la Play Store."
                        android:textSize="14sp"
                        android:textColor="@color/colorTextSecondary"
                        android:gravity="center"
                        android:lineSpacingExtra="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_instalar_hc"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_marginTop="24dp"
                        android:text="Instalar Health Connect"
                        android:textColor="@android:color/white"
                        app:backgroundTint="@color/colorAccent"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_completar_sin_hc_no_disp"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:text="Continuar sin Health Connect"
                        android:textColor="@color/colorTextSecondary"
                        style="@style/Widget.MaterialComponents.Button.TextButton" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─────────────────────────────────────────────────────────────── -->
            <!-- ESTADO 2: Sin permisos                                         -->
            <!-- ─────────────────────────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_hc_sin_permisos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white"
                tools:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="32dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔒"
                        android:textSize="48sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Permisos necesarios"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorTextPrimary"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Sportine necesita acceso a Health Connect para leer tus métricas de ejercicio: frecuencia cardíaca, pasos, calorías y más."
                        android:textSize="14sp"
                        android:textColor="@color/colorTextSecondary"
                        android:gravity="center"
                        android:lineSpacingExtra="4dp" />

                    <!-- Chips con los datos que se leerán -->
                    <com.google.android.material.chip.ChipGroup
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:chipSpacingHorizontal="4dp"
                        app:chipSpacingVertical="4dp">

                        <com.google.android.material.chip.Chip
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="❤️ Frecuencia cardíaca"
                            android:textSize="12sp"
                            android:clickable="false" />

                        <com.google.android.material.chip.Chip
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👟 Pasos"
                            android:textSize="12sp"
                            android:clickable="false" />

                        <com.google.android.material.chip.Chip
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔥 Calorías"
                            android:textSize="12sp"
                            android:clickable="false" />

                        <com.google.android.material.chip.Chip
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📍 Distancia"
                            android:textSize="12sp"
                            android:clickable="false" />

                        <com.google.android.material.chip.Chip
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚡ Velocidad"
                            android:textSize="12sp"
                            android:clickable="false" />
                    </com.google.android.material.chip.ChipGroup>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_solicitar_permisos_hc"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="24dp"
                        android:text="Dar permisos a Health Connect"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        app:backgroundTint="@color/colorAccent"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_completar_sin_hc_permisos"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_marginTop="4dp"
                        android:text="Continuar sin Health Connect"
                        android:textColor="@color/colorTextSecondary"
                        style="@style/Widget.MaterialComponents.Button.TextButton" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─────────────────────────────────────────────────────────────── -->
            <!-- ESTADO 3: Buscando sesiones                                    -->
            <!-- ─────────────────────────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_hc_buscando"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white"
                tools:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="48dp">

                    <ProgressBar
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:indeterminate="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Buscando sesiones de hoy..."
                        android:textSize="15sp"
                        android:textColor="@color/colorTextSecondary"
                        android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─────────────────────────────────────────────────────────────── -->
            <!-- ESTADO 4: Sin sesiones hoy                                     -->
            <!-- ─────────────────────────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_hc_sin_sesiones"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white"
                tools:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="32dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📭"
                        android:textSize="48sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Sin sesiones hoy"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorTextPrimary"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="No encontramos sesiones de ejercicio registradas en Health Connect para hoy. Puedes completar el entrenamiento sin vincular métricas."
                        android:textSize="14sp"
                        android:textColor="@color/colorTextSecondary"
                        android:gravity="center"
                        android:lineSpacingExtra="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_completar_sin_hc"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="24dp"
                        android:text="Completar sin métricas"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        app:backgroundTint="@color/colorAccent"
                        app:cornerRadius="12dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─────────────────────────────────────────────────────────────── -->
            <!-- ESTADO 5: Una sola sesión encontrada                           -->
            <!-- ─────────────────────────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_hc_una_sesion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Header de la card -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💪"
                            android:textSize="28sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sesión encontrada"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/colorTextPrimary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Health Connect detectó una sesión de hoy"
                                android:textSize="12sp"
                                android:textColor="@color/colorTextSecondary" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Detalle de la sesión -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/colorDivider"
                        android:backgroundTint="@color/colorPageBackground">

                        <TextView
                            android:id="@+id/tv_una_sesion_detalle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorTextPrimary"
                            android:gravity="center"
                            tools:text="Running  ·  45 min  ·  380 kcal" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Métricas en grid (se llenan desde el Fragment) -->
                    <LinearLayout
                        android:id="@+id/layout_metricas_preview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp"
                        android:weightSum="3">

                        <!-- Calorías -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tv_preview_calorias"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="@color/colorAccent"
                                tools:text="380" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="kcal 🔥"
                                android:textSize="11sp"
                                android:textColor="@color/colorTextSecondary" />
                        </LinearLayout>

                        <!-- Distancia -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tv_preview_distancia"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="#3B82F6"
                                tools:text="5.2 km" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Distancia 📍"
                                android:textSize="11sp"
                                android:textColor="@color/colorTextSecondary" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Botones -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_confirmar_sesion_hc"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="24dp"
                        android:text="Vincular esta sesión"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        app:backgroundTint="@color/colorAccent"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_no_vincular_una"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="No vincular"
                        android:textColor="@color/colorTextSecondary"
                        style="@style/Widget.MaterialComponents.Button.TextButton" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─────────────────────────────────────────────────────────────── -->
            <!-- ESTADO 6: Múltiples sesiones — spinner de selección            -->
            <!-- ─────────────────────────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_hc_multiples_sesiones"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white"
                tools:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔀"
                            android:textSize="28sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Varias sesiones hoy"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/colorTextPrimary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Elige cuál vincular al entrenamiento"
                                android:textSize="12sp"
                                android:textColor="@color/colorTextSecondary" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Spinner -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/colorDivider">

                        <Spinner
                            android:id="@+id/spinner_sesiones_hc"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:padding="12dp"
                            android:spinnerMode="dropdown" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Botones -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_vincular_seleccionada_hc"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="20dp"
                        android:text="Vincular sesión seleccionada"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        app:backgroundTint="@color/colorAccent"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_no_vincular_multi"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="No vincular ninguna"
                        android:textColor="@color/colorTextSecondary"
                        style="@style/Widget.MaterialComponents.Button.TextButton" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>