<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FAFAFA">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="120dp">

        <!-- ══ HEADER ══════════════════════════════════════════════ -->

        <ImageButton
            android:id="@+id/btn_volver"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:layout_marginTop="12dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Volver"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:tint="#1A1A1A" />

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/img_foto_perfil"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="60dp"
            android:src="@drawable/ic_perfil"
            app:civ_border_width="3dp"
            app:civ_border_color="#E5E7EB"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/text_nombre_alumno"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Alumno"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            app:layout_constraintTop_toBottomOf="@id/img_foto_perfil"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/layout_info_relacion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/text_nombre_alumno"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/text_dias_juntos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— días juntos"
                android:textSize="13sp"
                android:textColor="#6B7280" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" • "
                android:textSize="13sp"
                android:textColor="#6B7280" />

            <TextView
                android:id="@+id/text_entrenamientos_juntos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— entrenamientos"
                android:textSize="13sp"
                android:textColor="#6B7280" />
        </LinearLayout>

        <!-- ══ CONTENIDO ═══════════════════════════════════════════ -->

        <LinearLayout
            android:id="@+id/layout_content"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            app:layout_constraintTop_toBottomOf="@id/layout_info_relacion"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Resumen General -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resumen General"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginTop="16dp"
                android:baselineAligned="false">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_height="130dp"
                    android:layout_weight="1" android:layout_marginEnd="8dp"
                    app:cardCornerRadius="12dp" app:cardElevation="2dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:padding="16dp" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Total" android:textSize="14sp" android:textColor="#6B7280"/>
                        <TextView android:id="@+id/text_total_entrenamientos"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="32sp" android:textStyle="bold"
                            android:textColor="#1A1A1A" android:layout_marginTop="8dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Entrenamientos" android:textSize="12sp" android:textColor="#9CA3AF"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_height="130dp"
                    android:layout_weight="1" android:layout_marginStart="8dp"
                    app:cardCornerRadius="12dp" app:cardElevation="2dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:padding="16dp" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🔥 Racha" android:textSize="14sp" android:textColor="#6B7280"/>
                        <TextView android:id="@+id/text_racha_actual"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0 días" android:textSize="28sp" android:textStyle="bold"
                            android:textColor="#F59E0B" android:layout_marginTop="8dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Consecutivos" android:textSize="12sp" android:textColor="#9CA3AF"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginTop="12dp"
                android:baselineAligned="false">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_height="130dp"
                    android:layout_weight="1" android:layout_marginEnd="8dp"
                    app:cardCornerRadius="12dp" app:cardElevation="2dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:padding="16dp" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Este Mes" android:textSize="14sp" android:textColor="#6B7280"/>
                        <TextView android:id="@+id/text_entrenamientos_mes"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="32sp" android:textStyle="bold"
                            android:textColor="#10B981" android:layout_marginTop="8dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Completados" android:textSize="12sp" android:textColor="#9CA3AF"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_height="130dp"
                    android:layout_weight="1" android:layout_marginStart="8dp"
                    app:cardCornerRadius="12dp" app:cardElevation="2dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:padding="16dp" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Tendencia" android:textSize="14sp" android:textColor="#6B7280"/>
                        <TextView android:id="@+id/text_tendencia"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="→ Estable" android:textSize="18sp" android:textStyle="bold"
                            android:textColor="#6B7280" android:layout_marginTop="8dp" android:gravity="center"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Frecuencia -->
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Frecuencia de entrenamientos"
                android:textSize="20sp" android:textStyle="bold" android:textColor="#1A1A1A" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="12dp" app:cardCornerRadius="12dp" app:cardElevation="2dp">
                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/chart_frecuencia"
                    android:layout_width="match_parent" android:layout_height="220dp" android:padding="16dp"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══ Estadísticas por deporte ════════════════════════ -->
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Estadísticas por deporte"
                android:textSize="20sp" android:textStyle="bold" android:textColor="#1A1A1A" />

            <!-- Chips de deportes que el entrenador imparte a este alumno -->
            <HorizontalScrollView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:scrollbars="none" android:layout_marginTop="12dp" android:layout_marginBottom="12dp">
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_deportes"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    app:singleSelection="true" app:selectionRequired="true"/>
            </HorizontalScrollView>

            <!-- Cards de carrera (3 fijas) -->
            <LinearLayout android:id="@+id/layout_carrera"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:weightSum="3"
                android:baselineAligned="false" android:visibility="gone"
                android:layout_marginBottom="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_height="130dp" android:layout_weight="1"
                    android:layout_marginEnd="6dp" app:cardCornerRadius="16dp" app:cardElevation="0dp"
                    app:strokeWidth="2dp" app:strokeColor="@color/colorAccent" android:backgroundTint="@color/colorCardBackground">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="8dp">
                        <TextView android:id="@+id/card_emoji_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏆" android:textSize="24sp"/>
                        <TextView android:id="@+id/card_valor_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="22sp" android:textStyle="bold" android:textColor="@color/colorAccent" android:layout_marginTop="4dp"/>
                        <TextView android:id="@+id/card_titulo_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Métrica" android:textSize="10sp" android:textColor="@color/colorTextSecondary" android:gravity="center" android:maxLines="2"/>
                        <TextView android:id="@+id/card_sub_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mejor: 0" android:textSize="10sp" android:textColor="@color/colorTextSecondary"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_height="130dp" android:layout_weight="1"
                    android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
                    app:cardCornerRadius="16dp" app:cardElevation="0dp"
                    app:strokeWidth="2dp" app:strokeColor="@color/colorAccent" android:backgroundTint="@color/colorCardBackground">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="8dp">
                        <TextView android:id="@+id/card_emoji_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏆" android:textSize="24sp"/>
                        <TextView android:id="@+id/card_valor_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="22sp" android:textStyle="bold" android:textColor="@color/colorAccent" android:layout_marginTop="4dp"/>
                        <TextView android:id="@+id/card_titulo_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Métrica" android:textSize="10sp" android:textColor="@color/colorTextSecondary" android:gravity="center" android:maxLines="2"/>
                        <TextView android:id="@+id/card_sub_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mejor: 0" android:textSize="10sp" android:textColor="@color/colorTextSecondary"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_height="130dp" android:layout_weight="1"
                    android:layout_marginStart="6dp" app:cardCornerRadius="16dp" app:cardElevation="0dp"
                    app:strokeWidth="2dp" app:strokeColor="@color/colorAccent" android:backgroundTint="@color/colorCardBackground">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="8dp">
                        <TextView android:id="@+id/card_emoji_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏆" android:textSize="24sp"/>
                        <TextView android:id="@+id/card_valor_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="22sp" android:textStyle="bold" android:textColor="@color/colorAccent" android:layout_marginTop="4dp"/>
                        <TextView android:id="@+id/card_titulo_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Métrica" android:textSize="10sp" android:textColor="@color/colorTextSecondary" android:gravity="center" android:maxLines="2"/>
                        <TextView android:id="@+id/card_sub_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mejor: 0" android:textSize="10sp" android:textColor="@color/colorTextSecondary"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Chip toggle Gráficas / Historial -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_vista"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_graficas"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📊 Gráficas" android:textSize="13sp"
                    app:chipBackgroundColor="@color/colorCardBackground"
                    app:checkedIconVisible="false"
                    android:checkable="true" android:checked="true"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_historial"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📋 Historial" android:textSize="13sp"
                    app:chipBackgroundColor="@color/colorCardBackground"
                    app:checkedIconVisible="false"
                    android:checkable="true"/>
            </com.google.android.material.chip.ChipGroup>

            <!-- Gráficas dinámicas -->
            <LinearLayout
                android:id="@+id/layout_graficas_deporte"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"/>

            <!-- Historial dinámico -->
            <LinearLayout
                android:id="@+id/layout_historial_deporte"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- Loading -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminate="true"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Error -->
        <LinearLayout
            android:id="@+id/layout_error"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="❌" android:textSize="64sp"/>
            <TextView android:id="@+id/text_error"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="16dp" android:text="Error al cargar datos"
                android:textSize="16sp" android:textColor="#6B7280" android:gravity="center"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>